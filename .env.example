# --- Microsoft Foundry (Agent Service) ---
# Project endpoint from Foundry portal -> Project -> Overview -> "Endpoint"
# Format: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT="https://<account>.services.ai.azure.com/api/projects/<project>"
AZURE_AI_MODEL_DEPLOYMENT="gpt-4.1-mini"

# --- Azure Event Hubs (fibre telemetry signals) ---
EVENT_HUB_FQDN="<your-namespace>.servicebus.windows.net"
EVENT_HUB_NAME="fibre-signals"
EVENT_HUB_CONSUMER_GROUP="$Default"

# --- Microsoft Teams ---
# Use either an Incoming Webhook (simplest) OR a Workflow webhook URL.
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..."

# --- Mock D365 Field Service ---
D365_MOCK_BASE_URL="http://127.0.0.1:8765"
D365_MOCK_PORT="8765"

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# --- Demo behaviour ---
FIBREOPS_AUTO_DISPATCH="true"
FIBREOPS_OPTIMISER_ENABLED="true"
# Agent backend: auto | hosted | foundry | local
#   auto    -> hosted if `python -m fibreops.demo publish` has been run, else
#              foundry if AZURE_AI_PROJECT_ENDPOINT is set, else local
#   hosted  -> always bind to published FoundryAgents (errors if not published)
#   foundry -> always use Agent + FoundryChatClient (definition local)
#   local   -> always use deterministic LocalAgent shim (offline-safe)
FIBREOPS_AGENT_BACKEND="auto"
