# --- Microsoft Foundry (Agent Service) ---
# Project endpoint from Foundry portal -> Project -> Overview -> "Endpoint"
# Format: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT="https://<account>.services.ai.azure.com/api/projects/<project>"
AZURE_AI_MODEL_DEPLOYMENT="gpt-4.1-mini"

# --- Azure Event Hubs (fibre telemetry signals) ---
EVENT_HUB_FQDN="<your-namespace>.servicebus.windows.net"
EVENT_HUB_NAME="fibre-signals"
EVENT_HUB_CONSUMER_GROUP="$Default"

# --- Microsoft Teams ---
# Use either an Incoming Webhook (simplest) OR a Workflow webhook URL.
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..."

# --- Mock D365 Field Service ---
D365_MOCK_BASE_URL="http://127.0.0.1:8765"
D365_MOCK_PORT="8765"

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# --- Demo behaviour ---
FIBREOPS_AUTO_DISPATCH="true"
FIBREOPS_OPTIMISER_ENABLED="true"
# Agent backend: auto | hosted | foundry | local
#   auto    -> hosted if `python -m fibreops.demo publish` has been run, else
#              foundry if AZURE_AI_PROJECT_ENDPOINT is set, else local
#   hosted  -> always bind to published FoundryAgents (errors if not published)
#   foundry -> always use Agent + FoundryChatClient (definition local)
#   local   -> always use deterministic LocalAgent shim (offline-safe)
FIBREOPS_AGENT_BACKEND="auto"

# --- Foundry hosted agent (containerised, V1Preview) ---
# The "Outage Response Agent System" packaged as a container and deployed to
# Foundry Agent Service. Build src/fibreops/agents/Dockerfile.hosted, push to
# ACR, then `python -m fibreops.demo deploy-hosted`. See README "Deploy the
# containerised hosted agent". Inside the sandbox the platform injects
# FOUNDRY_PROJECT_ENDPOINT + MODEL_DEPLOYMENT_NAME (do NOT set those here).
FIBREOPS_HOSTED_AGENT_NAME="fibreops-outage-response"
# Full ACR image reference to deploy, e.g. myacr.azurecr.io/fibreops-outage-response:v1
FIBREOPS_HOSTED_IMAGE=""
# Per-session sandbox size: 0.5/1Gi, 1/2Gi, or 2/4Gi.
FIBREOPS_HOSTED_CPU="1"
FIBREOPS_HOSTED_MEMORY="2Gi"
# Port ResponsesHostServer listens on locally (Foundry hosts on 8088).
FIBREOPS_HOSTED_PORT="8088"
# Set to "true" to deploy the hosted agent during `azd up` (azure.yaml postdeploy
# hook runs scripts/deploy-hosted-agent.ps1). Off by default; use:
#   azd env set FIBREOPS_DEPLOY_HOSTED true
FIBREOPS_DEPLOY_HOSTED="false"

# --- Foundry hosted memory (procedural) ---
# Set a memory-store name to attach FoundryMemoryProvider to the agents.
# Empty = local SQLite memory (state/memory.db).
FOUNDRY_MEMORY_STORE_NAME=""
FOUNDRY_MEMORY_SCOPE=""

# --- Foundry Toolbox + Evals ---
# Light up Foundry hosted Toolbox tools (e.g. web_search) on the agents.
FIBREOPS_FOUNDRY_TOOLBOX="false"
# Run Foundry cloud Evaluators (evaluate_traces) in the optimiser in addition
# to the local rubric. Requires AZURE_AI_PROJECT_ENDPOINT.
FIBREOPS_FOUNDRY_EVALS="false"

# --- Azure AI Voice Live (NOC console "Speak status" / "Talk to agent") ---
# Realtime base endpoint of the Voice Live AI Services account (provisioned by
# infra/main.bicep). When set, the UI opens a Voice Live session via /ws/voice.
AZURE_VOICE_LIVE_ENDPOINT="https://<voice-account>.cognitiveservices.azure.com/"
# Voice Live MANAGED model name — NOT an Azure OpenAI deployment name. Valid:
# gpt-4o-mini, gpt-4o, gpt-4.1-mini, gpt-4.1, gpt-realtime, gpt-realtime-mini,
# gpt-5, gpt-5-mini. Voice Live models are fully managed — do NOT deploy them.
AZURE_VOICE_LIVE_MODEL="gpt-4o-mini"
# Default Azure TTS voice for one-shot status announcements.
AZURE_VOICE_LIVE_VOICE="en-GB-RyanNeural"
# Published Foundry agent id for the duplex "Talk to agent" mic session.
# Empty = direct-model mode against AZURE_VOICE_LIVE_MODEL.
AZURE_VOICE_LIVE_AGENT_ID=""
# Local-dev key fallback only; runtime uses the App Service managed identity
# (needs `Cognitive Services User` on the Voice Live account).
AZURE_VOICE_LIVE_API_KEY=""


